Config {
       font = "xft:Ubuntu:weight=bold:pixelsize=11:antialias=true:hinting=true"
     , additionalFonts  = [
                            "xft:Mononoki Nerd Font:pixelsize=12:antialias=true:hinting=true"
                          ]
    , bgColor           = "#282c34"
    , fgColor           = "#ff6c6b"
    , alpha             = 255
    , border            = BottomB
    , borderWidth       = 0
    , borderColor       = "#c0c5ce"
    , position          = TopSize C 100 24
    , textOffset        = -1
    , iconOffset        = -1
    , lowerOnStart      = True
    , hideOnStart       = False
    , allDesktops       = True
    , overrideRedirect  = True
    , pickBroadest      = False
    , persistent        = True
    , sepChar           = "%"
    , alignSep          = "}{"
    , template          = "\
      \  %UnsafeStdinReader% }{\
      \<fc=#666666>  |</fc>\
      \<fc=#ecbe7b>%cpu%</fc>\
      \<fc=#666666>  |</fc>\
      \<fc=#ff6c6b>%memory%</fc>\
      \<fc=#666666>  |</fc>\
      \<fc=#51afef>%disku%</fc>\
      \<fc=#666666>  |</fc>\
      \<fc=#98be65>%enp2s7%</fc>\
      \<fc=#666666>  |</fc>\
      \<fc=#46d9ff><action=`gsimplecal` button=1>%date%</action></fc>\
      \<fc=#666666><fn=1> |</fn></fc>%trayerpad%"

    , commands          =
        [ -- Time and date
          Run Date            "<fn=1> \xf133 </fn> %A %d %b %H:%M" "date" 50

          -- Network up and down
          -- To see available network devices, use the command:
          -- ip link show
        , Run Network        "enp2s7" ["-t", "<fn=1> \xf0aa </fn> <rx> kb<fn=1> \xf0ab </fn> <tx> kb"] 20

          -- Cpu usage in percent
        , Run Cpu         [ "--template" , "<fn=1> \xf108 </fn> cpu: <total>%"
                          , "--Low"      , "50"
                          , "--High"     , "85"
                          , "--low"      , "#ecbe7b"
                          , "--normal"   , "#ecbe7b"
                          , "--high"     , "#ff6c6b"
                          ] 20

          -- Ram used number and percent
        , Run Memory      [ "--template" , "<fn=1> \xf233 </fn> mem: <usedratio>%"
                          ] 20

          -- Disk space free
        , Run DiskU     [ ("/", "<fn=1> \xf0c7 </fn> hdd: <free> free")]
                          [ "--Low"      , "10"
                          , "--High"     , "40"
                          , "--low"      , "#ff6c6b"
                          , "--normal"   , "#ecbe7b"
                          , "--high"     , "#51afef"
                          ] 60

          -- Runs custom script to check for pacman updates.
          -- This script is in my dotfiles repo in .local/bin.
       -- , Run Com "/home/dt/.local/bin/pacupdate" [] "pacupdate" 36000

          -- Script that dynamically adjusts xmobar padding depending on number of trayer icons.
        , Run Com "/home/rafael/.config/xmobar/trayer-padding-icon" [] "trayerpad" 20

         -- Prints out the left side items such as workspaces, layout, etc.
        , Run UnsafeStdinReader
        ]
}
